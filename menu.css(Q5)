#nav_menu ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
}

#nav_menu ul li {
    float: left;
}

#nav_menu ul li a {
    display: block;
    width: 175px;
    padding: 1em 0;
    text-align: center;
    text-decoration: none;
    background-color: blue;
    color: white;
    font-weight: bold;
    border-right: 2px solid white;
}

#nav_menu ul li.lastitem {
    border-right: none;
}

#nav_menu ul li a.current {
    color: yellow;
}

/* 5. Aside ordered list */
aside ol {
    list-style-type: upper-roman;
}

/* 6. Aside unordered list */
aside ul {
    list-style-type: square;
}